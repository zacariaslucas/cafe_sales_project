/*
SQL data cleaning and exploratory analysis process designed to:
- Clean inconsistent and missing data
- Validate numerical integrity
- Infer missing values when possible
- Perform exploratory sales analysis
- Finally obtain business-oriented insights.
*/

-- New table created to preserve the original dataset

SELECT *
INTO cafe_sales_clean
FROM cafe_sales;

-- Looking for duplicates

WITH duplicates_cte AS (
	SELECT *,
	COUNT(*) OVER(PARTITION BY item, quantity, price_per_unit, total_spent, payment_method, location, transaction_date) AS duplicates
    FROM cafe_sales_clean
	WHERE item IS NOT NULL 
		AND quantity IS NOT NULL 
		AND price_per_unit IS NOT NULL 
		AND total_spent IS NOT NULL 
		AND payment_method IS NOT NULL
		AND location IS NOT NULL
		AND transaction_date IS NOT NULL
)
SELECT * FROM duplicates_cte
WHERE duplicates>1;

-- Some transactions share identical information, but since their IDs are different, they are considered unique transactions

-- Transaction_id as PK

UPDATE cafe_sales_clean
SET transaction_id = CAST(SUBSTRING(transaction_id,CHARINDEX('_', transaction_id) + 1, LEN(transaction_id)) AS INT);

ALTER TABLE cafe_sales_clean
ALTER COLUMN transaction_id INT NOT NULL;

ALTER TABLE cafe_sales_clean
ADD CONSTRAINT pk_cafe_sales_clean
PRIMARY KEY (transaction_id);

-- ERROR, UNKNOWN and NULL as 'Unknown'

SELECT DISTINCT(item) FROM cafe_sales_clean
ORDER BY item;

UPDATE cafe_sales_clean
SET item = 'Unknown'
WHERE item IN ('error','unknown') OR item IS NULL;

SELECT DISTINCT(payment_method) FROM cafe_sales_clean
ORDER BY payment_method;

UPDATE cafe_sales_clean
SET payment_method = 'Unknown'
WHERE payment_method IN ('error','unknown') OR payment_method IS NULL;

SELECT DISTINCT(location) FROM cafe_sales_clean
ORDER BY location;

UPDATE cafe_sales_clean
SET location = 'Unknown'
WHERE location IN ('error','unknown') OR location IS NULL;

-- Making sure numerical data makes sense

SELECT * FROM cafe_sales_clean
WHERE price_per_unit<0;

SELECT * FROM cafe_sales_clean
WHERE quantity<0;

SELECT * FROM cafe_sales_clean
WHERE total_spent<0;

SELECT * FROM cafe_sales_clean
WHERE price_per_unit*quantity != total_spent;

-- Each item appears to have a consistent price_per_unit, so missing values can be inferred

UPDATE t1
SET t1.price_per_unit = t2.price_per_unit
FROM cafe_sales_clean t1
JOIN (
    SELECT 
        item,
        MAX(price_per_unit) AS price_per_unit
    FROM cafe_sales_clean
    WHERE price_per_unit IS NOT NULL AND item !='Unknown'
    GROUP BY item
) t2
ON t1.item = t2.item
WHERE t1.price_per_unit IS NULL;

-- Transactions with unknown items are updated when their price uniquely identifies an item

SELECT DISTINCT price_per_unit, item FROM cafe_sales_clean
ORDER BY price_per_unit;

UPDATE t1
SET t1.item = t2.item
FROM cafe_sales_clean t1
JOIN (
    SELECT 
    MAX(item) AS item,
    price_per_unit
	FROM cafe_sales_clean
	WHERE item != 'Unknown'
		AND price_per_unit IS NOT NULL
	GROUP BY price_per_unit
	HAVING COUNT(DISTINCT item) = 1
) t2
ON t1.price_per_unit = t2.price_per_unit
WHERE t1.item = 'Unknown';

-- Some unknown item transactions remain because of uncertainty
-- The unknown item with a price of 30 is either cake or juice
-- And the unknown item with a price of 40 is either smoothie or sandwich

-- Since price_per_unit*quantity=total_spent, some NULLs can actually be updated

UPDATE cafe_sales_clean
SET quantity=total_spent/price_per_unit
WHERE quantity IS NULL;

UPDATE cafe_sales_clean
SET price_per_unit=total_spent/quantity
WHERE price_per_unit IS NULL;

UPDATE cafe_sales_clean
SET total_spent=price_per_unit*quantity
WHERE total_spent IS NULL;

-- 26 transaction still contain missing values for quantity or prices

SELECT * FROM cafe_sales_clean
WHERE quantity IS NULL OR price_per_unit IS NULL OR total_spent IS NULL;


-- Although some missing values remain, the dataset is now significantly cleaner and more suitable for analysis

SELECT COUNT(*) FROM cafe_sales_clean;    -- A total of 10.000 transactions were made

SELECT SUM(total_spent) FROM cafe_sales_clean;    -- Total revenue of 890.960 dollars

SELECT SUM(quantity) FROM cafe_sales_clean;   -- A total of 30.180 products were sold

SELECT SUM(total_spent)/COUNT(*) FROM cafe_sales_clean;   -- 89 dollars is the average amount spent in a transaction

--Median value of total_spent

SELECT DISTINCT
    PERCENTILE_CONT(0.5)
    WITHIN GROUP (ORDER BY total_spent)
    OVER () AS median
FROM cafe_sales_clean;								-- 80 dollars is the median of total_spent in a transaction

SELECT SUM(quantity)/COUNT(*) FROM cafe_sales_clean;   -- 3 items is the average amount of products sold in a transaction

-- Distribution of transactions by item

SELECT 
	item,
	CAST(
		100.0*COUNT(*) / (SELECT COUNT(*) FROM cafe_sales_clean) 
		AS DECIMAL(10,2)
	) item_percentage,
	SUM(total_spent) total_spent_per_item,
	ROUND(100.0*SUM(total_spent) / (SELECT SUM(total_spent) FROM cafe_sales_clean),2) total_revenue_percentage
FROM cafe_sales_clean
GROUP BY item
ORDER BY total_revenue_percentage DESC;

-- Distribution of transactions by payment_method

SELECT 
	payment_method, 
	CAST(
		100.0*COUNT(*) / (SELECT COUNT(*) FROM cafe_sales_clean) 
		AS DECIMAL(10,2)
	) payment_method_percentage,
	SUM(total_spent) total_spent_per_payment_method,
	ROUND(100.0*SUM(total_spent) / (SELECT SUM(total_spent) FROM cafe_sales_clean),2) total_revenue_percentage
FROM cafe_sales_clean
GROUP BY payment_method
ORDER BY total_revenue_percentage DESC;

-- Distribution of transactions by location

SELECT 
	location, 
	CAST(
		100.0*COUNT(*) / (SELECT COUNT(*) FROM cafe_sales_clean) 
		AS DECIMAL(10,2)
	) location_percentage,
	SUM(total_spent) total_spent_per_location,
	ROUND(100.0*SUM(total_spent) / (SELECT SUM(total_spent) FROM cafe_sales_clean),2) total_revenue_percentage
FROM cafe_sales_clean
GROUP BY location
ORDER BY total_revenue_percentage DESC;

-- Comparing the impact of location on revenue by item

SELECT 
	location,
	item,
	ROUND(100.0*SUM(total_spent) / (SELECT SUM(total_spent) FROM cafe_sales_clean),2) total_revenue_percentage
FROM cafe_sales_clean
WHERE location != 'Unknown' AND item != 'Unknown' 
GROUP BY location, item
ORDER BY total_revenue_percentage DESC;

-- Comparing the impact of location on number of transactions by item

SELECT 
	location,
	item,
	COUNT(*) nr_transactions
FROM cafe_sales_clean
WHERE location != 'Unknown' AND item != 'Unknown' 
GROUP BY location, item
ORDER BY nr_transactions DESC;

-- Comparing the impact of location on the number of products sold

SELECT 
	location,
	SUM(quantity) nr_products
FROM cafe_sales_clean
WHERE location != 'Unknown' 
GROUP BY location
ORDER BY nr_products DESC;

-- Distribution of transactions by month

SELECT 
	DATENAME(MONTH, transaction_date) month, 
	CAST(
		100.0*COUNT(*) / (SELECT COUNT(*) FROM cafe_sales_clean) 
		AS DECIMAL(10,2)
	) month_percentage,
	SUM(total_spent) total_spent_per_month,
	ROUND(100.0*SUM(total_spent) / (SELECT SUM(total_spent) FROM cafe_sales_clean),2) total_revenue_percentage
FROM cafe_sales_clean
GROUP BY DATENAME(MONTH, transaction_date)
ORDER BY total_revenue_percentage DESC;

--  Total_spent frequences (histogram)

SELECT
	total_spent,
	COUNT(*) nr_transactions_per_total_spent
FROM cafe_sales_clean
WHERE total_spent IS NOT NULL
GROUP BY total_spent
ORDER BY 1;
